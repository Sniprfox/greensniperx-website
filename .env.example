# ─── SUPABASE ────────────────────────────────────────────────
# supabase.com → your project → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase-settings

# ─── STRIPE ──────────────────────────────────────────────────
# dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MEMBERSHIP_PRICE_ID=price_...      # $199/month
STRIPE_CUSTOM_STRATEGY_PRICE_ID=price_... # $249 one-time

# ─── TWILIO (SMS alerts) ──────────────────────────────────────
# console.twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...

# ─── RESEND (emails) ──────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=re_...
EMAIL_FROM=GreenSniperX <hello@greensniperx.com>
ADMIN_EMAIL=you@youremail.com

# ─── APP ─────────────────────────────────────────────────────
FRONTEND_URL=https://greensniperx.com
ENVIRONMENT=production
